// ============================================================
// user.prisma
// User domain schema.
//
// Maps 1-to-1 with the PostgreSQL `User` table visible in the
// DB diagram:
//   id                        uuid          PK (NN)
//   name                      varchar       NN
//   email                     varchar
//   phone                     varchar
//   password                  varchar       NN
//   avatar                    text
//   acc_verification_otp      varchar
//   acc_verified              boolean true  NN (default false)
//   role                      user_role     NN (ENUM)
//   reset_pass_otp            varchar
//   reset_pass_otp_expired_at timestamptz
//   created_at                timestamptz   NN
//   updated_at                timestamptz
//
// Design decisions:
//  - All sensitive fields (password, OTPs) are stored in the
//    same model but NEVER selected by default via DAO layer.
//  - `acc_verification_otp` is a 6-digit string OTP (not UUID
//    token), matching the table column name in the diagram.
//  - `reset_pass_otp` / `reset_pass_otp_expired_at` handle
//    both mobile OTP and web token flows via platform flag.
//  - UUID PK over serial int: globally unique, safe to expose
//    in URLs, prevents enumeration attacks.
//  - `@@map("User")` keeps Prisma model name in PascalCase
//    while the actual table is "User" (as shown in diagram).
// ============================================================

enum UserRole {
  CUSTOMER
  SHOP_OWNER

  @@map("user_role")
}

model User {
  // Primary Key — UUID v4 generated by PostgreSQL
  id String @id @default(uuid()) @db.Uuid

  // Profile
  name   String  @db.VarChar(255)
  email  String? @unique @db.VarChar(255)
  /// E.164-normalised Bangladeshi mobile number (+8801XXXXXXXXX).
  /// Unique when present — mutually exclusive with email as login identifier.
  phone  String? @unique @db.VarChar(20)
  avatar String? @db.Text

  // Auth — password excluded from default selects in DAO
  password String @db.VarChar(255)

  // Email verification via 6-digit OTP
  acc_verification_otp String? @db.VarChar(10)
  acc_verified         Boolean @default(false)

  // Role-based access control
  role UserRole

  // Password reset — single OTP field for both mobile (digit OTP)
  // and web (UUID token) flows. Platform decides interpretation.
  reset_pass_otp            String?   @db.VarChar(255)
  reset_pass_otp_expired_at DateTime? @db.Timestamptz

  // Audit timestamps — managed by Prisma
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime? @updatedAt @db.Timestamptz

  @@index([email])
  @@index([phone])
  @@index([role])
  @@map("User")
}
