PORT=8080
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT
JWT_EXPIRES_IN=2592000
JWT_SECRET=change_this_to_a_long_random_secret_in_production

# Password hashing
BCRYPT_SALT_ROUNDS=10

# SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=example@gmail.com
MAIL_PASS=aaaa bbbb cccc dddd
MAIL_FROM_NAME=MyApp
MAIL_FROM_EMAIL=no-reply@myapp.com

# PostgreSQL (Prisma)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/myapp_db?schema=public

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB_AUTH=1
REDIS_DB_SESSION=2
REDIS_DB_THROTTLE=3
REDIS_DB_EMAIL_QUEUE=4
REDIS_DB_AUTH_EMAIL_QUEUE=5
REDIS_DB_AUTH_SMS_QUEUE=6

# SMS Gateway (sms.net.bd)
SMSNET_API_BASE=https://api.sms.net.bd
SMSNET_API_PATH=/sendsms
SMSNET_API_KEY=
SMSNET_TIMEOUT_MS=10000
